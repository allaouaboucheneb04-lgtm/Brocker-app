rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return userExists() && userData().role == "superadmin";
    }

    function isBroker() {
      return userExists() && userData().role == "broker";
    }

    function isDriver() {
      return userExists() && userData().role == "driver";
    }

    function myBrokerId() {
      return userData().brokerId;
    }

    function isAllowedSuperEmail() {
      return request.auth.token.email == "allaouaboucheneb04@gmail.com"
        || request.auth.token.email == "allaouaboucheneb06@gmail.com";
    }

    function myInvite() {
      return get(/databases/$(database)/documents/invitations/$(request.auth.token.email)).data;
    }

    function inviteExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/invitations/$(request.auth.token.email));
    }

    function validInvitedUserCreate() {
      return signedIn()
        && request.resource.data.emailLower == request.auth.token.email
        && inviteExists()
        && myInvite().used == false
        && request.resource.data.role == myInvite().role
        && request.resource.data.brokerId == myInvite().brokerId;
    }

    // USERS
    match /users/{uid} {
      allow read, write: if isSuperAdmin();

      // Création superadmin initiale autorisée seulement pour tes emails.
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.role == "superadmin"
        && request.resource.data.emailLower == request.auth.token.email
        && isAllowedSuperEmail();

      // Création du profil broker/chauffeur après acceptation d'une invitation.
      allow create: if signedIn()
        && request.auth.uid == uid
        && validInvitedUserCreate();

      // Chaque utilisateur lit/met à jour son profil de base.
      allow read, update: if signedIn() && request.auth.uid == uid;

      // Broker lit les utilisateurs de son entreprise.
      allow read: if isBroker() && resource.data.brokerId == myBrokerId();
    }

    // BROKERS
    match /brokers/{brokerId} {
      allow read, write: if isSuperAdmin();
      allow read, update: if isBroker() && brokerId == myBrokerId();
    }

    // DRIVERS
    match /drivers/{driverId} {
      allow read, write: if isSuperAdmin();
      allow create: if isBroker() && request.resource.data.brokerId == myBrokerId();
      allow read, update, delete: if isBroker() && resource.data.brokerId == myBrokerId();
      allow read: if isDriver() && resource.data.uid == request.auth.uid;
    }

    // INVITATIONS
    match /invitations/{inviteId} {
      allow read, write: if isSuperAdmin();

      // Broker invite uniquement ses chauffeurs.
      allow create: if isBroker()
        && request.resource.data.role == "driver"
        && request.resource.data.brokerId == myBrokerId();

      allow read, update, delete: if isBroker()
        && resource.data.brokerId == myBrokerId();

      // Utilisateur connecté peut lire son invitation avant création du profil.
      allow read: if signedIn()
        && inviteId == request.auth.token.email
        && resource.data.emailLower == request.auth.token.email
        && resource.data.used == false;

      // Utilisateur invité peut marquer son invitation utilisée.
      allow update: if signedIn()
        && inviteId == request.auth.token.email
        && resource.data.emailLower == request.auth.token.email
        && resource.data.used == false
        && request.resource.data.used == true;
    }

    // WEEKS
    match /weeks/{weekId} {
      allow read, write: if isSuperAdmin();
      allow create: if isBroker() && request.resource.data.brokerId == myBrokerId();
      allow read, update, delete: if isBroker() && resource.data.brokerId == myBrokerId();
      allow read: if isDriver() && resource.data.driverId == request.auth.uid;
    }

    // DAILY VEHICLES
    match /dailyVehicles/{docId} {
      allow read, write: if isSuperAdmin();
      allow create: if isBroker() && request.resource.data.brokerId == myBrokerId();
      allow read, update, delete: if isBroker() && resource.data.brokerId == myBrokerId();
      allow read: if isDriver() && resource.data.driverId == request.auth.uid;
      allow create, update: if isDriver() && request.resource.data.driverId == request.auth.uid;
    }

    // PARCEL DETAILS
    match /parcelDetails/{docId} {
      allow read, write: if isSuperAdmin();
      allow create: if isBroker() && request.resource.data.brokerId == myBrokerId();
      allow read, update, delete: if isBroker() && resource.data.brokerId == myBrokerId();
      allow read: if isDriver() && resource.data.driverId == request.auth.uid;
    }

    // SETTINGS
    match /settings/{docId} {
      allow read, write: if isSuperAdmin();
      allow create: if isBroker() && request.resource.data.brokerId == myBrokerId();
      allow read, update, delete: if isBroker() && resource.data.brokerId == myBrokerId();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

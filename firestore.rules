rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isAdmin() { return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && userDoc().data.role == 'admin'; }
    match /users/{userId} { allow read: if isAdmin() || (signedIn() && request.auth.uid == userId); allow write: if isAdmin(); }
    match /drivers/{driverId} { allow read: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid); allow write: if isAdmin(); }
    match /weeks/{weekId} { allow read: if isAdmin() || (signedIn() && resource.data.driverId == request.auth.uid); allow create, update, delete: if isAdmin() || (signedIn() && request.resource.data.driverId == request.auth.uid); }
    match /settings/{docId} { allow read: if signedIn(); allow write: if isAdmin(); }
    match /{document=**} { allow read, write: if false; }
  }
}

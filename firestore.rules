rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return userExists() && userData().role == "superadmin";
    }

    function isBroker() {
      return userExists() && userData().role == "broker";
    }

    function isDriver() {
      return userExists() && userData().role == "driver";
    }

    function myBrokerId() {
      return userData().brokerId;
    }

    function myDriverId() {
      return userData().driverId;
    }

    // Profil utilisateur global. Le Super Admin est créé MANUELLEMENT dans Firestore.
    match /users/{uid} {
      allow read, write: if isSuperAdmin();

      allow read, update: if signedIn()
        && request.auth.uid == uid;

      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.role != "superadmin";
    }

    // Index global des invitations par email, nécessaire avant que le profil app existe.
    match /invitations/{inviteId} {
      allow read, write: if isSuperAdmin();

      allow create, update: if isBroker()
        && request.resource.data.brokerId == myBrokerId();

      allow read: if signedIn()
        && resource.data.emailLower == request.auth.token.email.lower();

      allow update: if signedIn()
        && resource.data.emailLower == request.auth.token.email.lower()
        && request.resource.data.used == true;
    }

    // Document principal du broker.
    match /brokers/{brokerId} {
      allow read, write: if isSuperAdmin();

      allow read, update: if isBroker()
        && brokerId == myBrokerId();

      allow read: if isDriver()
        && brokerId == myBrokerId();
    }

    // Toutes les données appartenant à un broker.
    match /brokers/{brokerId}/{document=**} {
      allow read, write: if isSuperAdmin();

      allow read, write: if isBroker()
        && brokerId == myBrokerId();

      allow read: if isDriver()
        && brokerId == myBrokerId();

      // Le chauffeur peut mettre à jour ses propres journées/véhicules si le document indique son driverId.
      allow create, update: if isDriver()
        && brokerId == myBrokerId()
        && request.resource.data.driverId == myDriverId();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

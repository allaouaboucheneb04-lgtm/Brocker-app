rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return signedIn() && userDoc().exists() ? userDoc().data.role : null;
    }

    function isSuperAdmin() { return role() == 'superadmin'; }
    function isBroker() { return role() == 'broker'; }
    function isDriver() { return role() == 'driver'; }

    function myBrokerId() {
      return userDoc().data.brokerId;
    }

    function sameBrokerResource() {
      return signedIn() && resource.data.brokerId == myBrokerId();
    }

    function sameBrokerRequest() {
      return signedIn() && request.resource.data.brokerId == myBrokerId();
    }

    match /users/{userId} {
      allow read: if isSuperAdmin()
        || request.auth.uid == userId
        || (isBroker() && resource.data.brokerId == myBrokerId());

      allow create: if isSuperAdmin()
        || (isBroker() && request.resource.data.role == 'driver' && request.resource.data.brokerId == myBrokerId());

      allow update: if isSuperAdmin()
        || request.auth.uid == userId
        || (isBroker() && resource.data.role == 'driver' && resource.data.brokerId == myBrokerId());

      allow delete: if isSuperAdmin();
    }

    match /brokers/{brokerId} {
      allow read: if isSuperAdmin() || (isBroker() && brokerId == myBrokerId());
      allow write: if isSuperAdmin();
    }

    match /drivers/{driverId} {
      allow read: if isSuperAdmin()
        || (isBroker() && sameBrokerResource())
        || (isDriver() && resource.data.uid == request.auth.uid);
      allow create: if isSuperAdmin() || (isBroker() && sameBrokerRequest());
      allow update: if isSuperAdmin() || (isBroker() && sameBrokerResource());
      allow delete: if isSuperAdmin() || (isBroker() && sameBrokerResource());
    }

    match /weeks/{weekId} {
      allow read: if isSuperAdmin()
        || (isBroker() && sameBrokerResource())
        || (isDriver() && resource.data.driverId == request.auth.uid);
      allow create: if isSuperAdmin() || (isBroker() && sameBrokerRequest());
      allow update: if isSuperAdmin() || (isBroker() && sameBrokerResource());
      allow delete: if isSuperAdmin() || (isBroker() && sameBrokerResource());
    }

    match /dailyVehicles/{docId} {
      allow read: if isSuperAdmin()
        || (isBroker() && sameBrokerResource())
        || (isDriver() && resource.data.driverId == request.auth.uid);
      allow create: if isSuperAdmin()
        || (isBroker() && sameBrokerRequest())
        || (isDriver() && request.resource.data.driverId == request.auth.uid);
      allow update: if isSuperAdmin()
        || (isBroker() && sameBrokerResource())
        || (isDriver() && resource.data.driverId == request.auth.uid);
      allow delete: if isSuperAdmin() || (isBroker() && sameBrokerResource());
    }

    match /parcelDetails/{docId} {
      allow read: if isSuperAdmin()
        || (isBroker() && sameBrokerResource())
        || (isDriver() && resource.data.driverId == request.auth.uid);
      allow write: if isSuperAdmin() || (isBroker() && sameBrokerRequest());
    }

    match /settings/{brokerId} {
      allow read: if isSuperAdmin() || (isBroker() && brokerId == myBrokerId()) || isDriver();
      allow write: if isSuperAdmin() || (isBroker() && brokerId == myBrokerId());
    }

    match /{document=**} { allow read, write: if false; }
  }
}

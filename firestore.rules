rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return userExists()
        && userData().role == 'superadmin'
        && userData().active != false;
    }

    function isBroker() {
      return userExists()
        && userData().role == 'broker'
        && userData().active != false;
    }

    function isDriver() {
      return userExists()
        && userData().role == 'driver'
        && userData().active != false;
    }

    function myBrokerId() {
      return userData().brokerId;
    }

    function isMyBroker(brokerId) {
      return isBroker() && brokerId == myBrokerId();
    }

    function isBrokerChild(brokerId) {
      return isSuperAdmin() || isMyBroker(brokerId);
    }

    // Global user index. Superadmin is created manually only.
    match /users/{uid} {
      allow read, write: if isSuperAdmin();
      allow read, update: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.role in ['broker', 'driver']
        && request.resource.data.active != false;
      allow read: if isBroker() && resource.data.brokerId == myBrokerId();
    }

    // Broker root document. Broker can read/update only its root profile.
    match /brokers/{brokerId} {
      allow read, write: if isSuperAdmin();
      allow read, update: if isMyBroker(brokerId);

      // Nested broker-owned data.
      match /drivers/{driverId} {
        allow read, write: if isBrokerChild(brokerId);
        allow read, update: if isDriver()
          && resource.data.uid == request.auth.uid
          && resource.data.active != false;
      }

      match /weeks/{weekId} {
        allow read, write: if isBrokerChild(brokerId);
        allow read: if isDriver()
          && resource.data.driverUid == request.auth.uid;
      }

      match /dailyVehicles/{docId} {
        allow read, write: if isBrokerChild(brokerId);
        allow read, create, update: if isDriver()
          && request.resource.data.driverUid == request.auth.uid;
      }

      match /parcelDetails/{docId} {
        allow read, write: if isBrokerChild(brokerId);
        allow read: if isDriver()
          && resource.data.driverUid == request.auth.uid;
      }

      match /settings/{docId} {
        allow read, write: if isBrokerChild(brokerId);
      }

      match /notifications/{docId} {
        allow read, write: if isBrokerChild(brokerId);
      }

      match /duplicateInvoices/{docId} {
        allow read, write: if isBrokerChild(brokerId);
      }

      match /history/{docId} {
        allow read, write: if isBrokerChild(brokerId);
      }

      match /stations/{docId} {
        allow read, write: if isBrokerChild(brokerId);
      }

      match /subscriptions/{docId} {
        allow read, write: if isSuperAdmin();
        allow read: if isMyBroker(brokerId);
      }

      match /reports/{docId} {
        allow read, write: if isBrokerChild(brokerId);
      }

      match /invitations/{inviteId} {
        allow read, write: if isBrokerChild(brokerId);
      }
    }

    // Global invitation index by email, required before a new user has brokerId.
    // It only stores invite metadata and points to brokerId/driverId.
    match /invitations/{inviteId} {
      allow read, write: if isSuperAdmin();
      allow read, update: if signedIn()
        && inviteId == request.auth.token.email.lower();
      allow read, create, update, delete: if isBroker()
        && request.resource.data.brokerId == myBrokerId()
        && request.resource.data.role == 'driver';
    }

    match /plans/{planId} {
      allow read: if signedIn();
      allow write: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

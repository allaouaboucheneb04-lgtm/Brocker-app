rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function role() { return userDoc().data.role; }
    function brokerId() { return userDoc().data.brokerId; }
    function isSuperAdmin() { return signedIn() && userDoc().data.role == 'superadmin'; }
    function isBroker() { return signedIn() && userDoc().data.role == 'broker'; }
    function isDriver() { return signedIn() && userDoc().data.role == 'driver'; }
    function sameBroker(id) { return signedIn() && brokerId() == id; }

    match /users/{userId} {
      allow read, write: if isSuperAdmin();
      allow read: if signedIn() && request.auth.uid == userId;
      allow read: if isBroker() && resource.data.brokerId == brokerId();
      allow create: if signedIn() && request.auth.uid == userId && request.resource.data.email == request.auth.token.email;
      allow update: if signedIn() && request.auth.uid == userId;
    }

    match /brokers/{brokerDocId} {
      allow read, write: if isSuperAdmin();
      allow read: if isBroker() && brokerDocId == brokerId();
    }

    match /invitations/{email} {
      allow read, write: if isSuperAdmin();
      allow read, create, update: if isBroker() && request.resource.data.brokerId == brokerId();
      allow read, update: if signedIn() && email == request.auth.token.email;
    }

    match /drivers/{driverId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isBroker() && resource.data.brokerId == brokerId();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read, update: if isDriver() && resource.data.uid == request.auth.uid;
    }

    match /weeks/{weekId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isBroker() && resource.data.brokerId == brokerId();
      allow create: if isBroker() && request.resource.data.brokerId == brokerId();
      allow read: if isDriver() && resource.data.driverId == request.auth.uid;
    }

    match /dailyVehicles/{docId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isBroker() && resource.data.brokerId == brokerId();
      allow read: if isDriver() && resource.data.driverId == request.auth.uid;
      allow create, update: if isDriver() && request.resource.data.driverId == request.auth.uid;
    }

    match /parcelDetails/{docId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isBroker() && resource.data.brokerId == brokerId();
      allow read: if isDriver() && resource.data.driverId == request.auth.uid;
    }

    match /settings/{docId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isBroker() && resource.data.brokerId == brokerId();
      allow create: if isBroker() && request.resource.data.brokerId == brokerId();
    }

    match /{document=**} { allow read, write: if false; }
  }
}
